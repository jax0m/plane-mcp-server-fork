# Plane MCP Server - Test Environment Variables
# Copy this file to .env.test.local and fill in your values
#
# Usage:
#   Local testing:  export $(cat .env.test.local | xargs) && ./scripts/test_stdio.sh -v
#   CI/CD: Configure these as GitHub Secrets with the same names
#
# GitHub Actions Secret Names (must match exactly):
#   PLANE_TEST_API_KEY          - Your Plane API key
#   PLANE_TEST_WORKSPACE_SLUG   - Your workspace slug
#   PLANE_TEST_BASE_URL         - Optional, defaults to https://api.plane.so
#
# Run tests:
#   Stdio tests (recommended for CI): ./scripts/test_stdio.sh -v
#   HTTP tests (requires local server): ./scripts/test_local.sh -v

# Required: Plane API configuration
# These variables are used by both stdio and HTTP transport tests
PLANE_TEST_BASE_URL=https://api.plane.so
PLANE_TEST_API_KEY=your_api_key_here
PLANE_TEST_WORKSPACE_SLUG=your_workspace_slug_here

# Optional: MCP server URL for HTTP transport tests (default: http://localhost:8211)
# Used by test_integration.py and test_stateless_http.py
PLANE_TEST_MCP_URL=http://localhost:8211

# Optional: OAuth provider settings (only needed if testing OAuth flow)
# Used by test_oauth_security.py
# PLANE_OAUTH_PROVIDER_CLIENT_ID=your_oauth_client_id
# PLANE_OAUTH_PROVIDER_CLIENT_SECRET=your_oauth_client_secret
# PLANE_OAUTH_PROVIDER_BASE_URL=http://localhost:8211
